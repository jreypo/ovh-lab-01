# OVH AI Endpoints credentials (copy to .env and fill in)
OVH_AI_API_KEY=
OVH_AI_BASE_URL=

# Model identifiers as exposed by OVH AI Endpoints
OVH_EMBEDDING_MODEL=bge-multilingual-gemma2
OVH_CHAT_MODEL=gpt-oss-120b

# ChromaDB (matches docker-compose service)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Path to the Hugo blog repo (source of the corpus)
BLOG_REPO_PATH=/Users/jreypo/Documents/Workspace/jreypo.github.io
BLOG_POSTS_SUBDIR=content/posts
